# Copy to .env (docker compose loads it automatically) and fill these in.

# Beacon API (consensus) endpoint proofessoor reads blocks from. Required.
BEACON_URL=https://your-beacon-api

# Optional: extra Beacon API header for authenticated providers, "Name: Value".
# BEACON_HEADER=X-API-Key: your-key

# Host port for the proofessoor dashboard (the container always serves :9100).
# Override if 19100 is already taken on your host.
PROOFESSOOR_PORT=19100
